# ── LiveKit ──────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── OpenAI Realtime API ─────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── Logging ──────────────────────────────────────────────
# Where per-session transcripts are written.
# Server default: /var/log/sada/sessions
SADA_LOG_DIR=logs

# ── Hotel API Mode ───────────────────────────────────────
# "mock"      → realistic demo data, no external API needed (default)
# "hotelbeds" → real hotel data via Hotelbeds APItude API
HOTEL_API_MODE=mock

# ── Hotelbeds (only needed if HOTEL_API_MODE=hotelbeds) ──
# HOTELBEDS_API_KEY=your_hotelbeds_key
# HOTELBEDS_API_SECRET=your_hotelbeds_secret
# HOTELBEDS_ENV=test
