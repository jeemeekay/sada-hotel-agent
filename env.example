# ── LiveKit ──────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Hotel API Mode ───────────────────────────────────────
# "mock"      → realistic demo data, no external API needed (default)
# "hotelbeds" → real hotel data via Hotelbeds APItude API
HOTEL_API_MODE=mock

# ── Hotelbeds (only needed if HOTEL_API_MODE=hotelbeds) ──
# Sign up at https://developer.hotelbeds.com for a free API key
# HOTELBEDS_API_KEY=your_hotelbeds_key
# HOTELBEDS_API_SECRET=your_hotelbeds_secret
# HOTELBEDS_ENV=test

# ── Anthropic (Claude LLM) ──────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Deepgram (STT) ─────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Cartesia (TTS) ─────────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key
